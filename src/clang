#!/bin/bash
#
# clang - Wrapper to redirect clang calls to 'zig cc'.
#
# This script is designed to be a resilient drop-in replacement for clang in
# a build system. It correctly handles three scenarios:
# 1. Non-macOS builds (or compiler checks like '-v'): It passes args through.
# 2. Native macOS builds: It applies necessary argument fixes.
# 3. Cross-compiling to macOS: It applies necessary argument fixes.
#
# Key logic:
# - It first detects if the command is targeting macOS.
# - If not, it safely exits and executes zig cc with the original arguments.
# - If it IS a macOS target, it performs all the necessary transformations:
#   - Moves the corrected '--target=...' flag to the front.
#   - Removes redundant system libraries (-lobjc, -lz, etc.).
#   - Fixes bare framework names (CoreFoundation -> -framework CoreFoundation).
#   - Removes other incompatible flags (-ld_classic).

set -euo pipefail

main() {
    # Use a bash array to preserve arguments with spaces
    local -a original_args=("$@")

    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Original args from build system:"
        printf "  '%s'\n" "${original_args[@]}"
    fi

    if ! command -v zig &>/dev/null; then
        echo "Error: zig is not on the PATH." >&2
        exit 1
    fi

    # --- Detection Phase ---
    # First, determine if this command is targeting macOS at all.
    local is_macos_target=false
    local target_arg=""
    for arg in "${original_args[@]}"; do
        case "$arg" in
        *-apple-darwin* | -framework | --target=*-macos*)
            is_macos_target=true
            if [[ "$arg" == --target=* ]]; then
                target_arg="$arg"
            fi
            ;;
        esac
    done

    # --- Decision Phase ---
    # If this is NOT a macOS build, just pass everything to zig cc and we're done.
    # This handles Linux builds, version checks (-v), etc.
    if [[ "$is_macos_target" == false ]]; then
        echo "[clang.sh] Not a macOS target. Passing arguments through directly."
        exec zig cc "${original_args[@]}"
    fi

    # --- Transformation Phase for macOS ---
    echo "[clang.sh] Detected macOS target. Applying transformations..."

    # Correct the target triple to what Zig expects
    if [[ -z "$target_arg" ]]; then
        echo "[ERROR] macOS target detected, but no '--target' flag found. Cannot proceed." >&2
        exit 1
    fi
    local corrected_target="${target_arg}-none"
    corrected_target="${corrected_target//-macos-none-none/-macos-none}" # Prevent double adding
    echo "[clang.sh] Corrected target: $corrected_target"

    # Build the final command, starting with the corrected target
    local -a final_command=("cc" "$corrected_target")

    # Use a robust 'while' loop to filter the original arguments
    local -a args_to_process=("$@")
    while [[ ${#args_to_process[@]} -gt 0 ]]; do
        local current_arg="${args_to_process[0]}"
        local next_arg="${args_to_process[1]:-}"

        case "$current_arg" in
        # DISCARD the original target flag
        --target=*)
            unset 'args_to_process[0]'
            ;;

        # KEEP correctly formed framework flags
        -framework)
            if [[ -n "$next_arg" ]]; then
                final_command+=("$current_arg" "$next_arg")
                unset 'args_to_process[0]' 'args_to_process[1]'
            else
                unset 'args_to_process[0]'
            fi
            ;;

        # FIX bare framework names
        CoreFoundation | Foundation | Security | AppKit | GSS | CryptoKit)
            final_command+=("-framework" "$current_arg")
            unset 'args_to_process[0]'
            ;;

        # DISCARD problematic flags
        -lobjc | -lswiftCore | -lswiftFoundation | -lz | -licucore | -lm | -ldl | -ld_classic | -L/usr/lib/swift)
            unset 'args_to_process[0]'
            ;;

        # KEEP everything else
        *)
            final_command+=("$current_arg")
            unset 'args_to_process[0]'
            ;;
        esac
        # Re-index the array after unsetting elements
        args_to_process=("${args_to_process[@]}")
    done

    # --- Execution Phase ---
    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Final modified command to be executed:"
        printf "  'zig' "
        printf "'%s' " "${final_command[@]}"
        echo
    fi

    exec zig "${final_command[@]}"
}

# --- Script Entry Point ---
main "$@"
