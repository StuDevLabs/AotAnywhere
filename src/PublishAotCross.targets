<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Windows and macOS hosts targeting Linux are supported -->
  <Import Project="Crosscompile.targets" Condition="$(RuntimeIdentifier.Contains('linux')) and ($([MSBuild]::IsOSPlatform('Windows')) or $([MSBuild]::IsOSPlatform('OSX')))" />

</Project>
